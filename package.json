{
  "name": "master-hand-vscode",
  "displayName": "Master Hand",
  "description": "Models as helpers, not autopilot. Repo-aware suggestions with an explicit approval boundary.",
  "version": "0.1.0",
  "publisher": "artie-mortus",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node tests/run.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "masterHand",
          "title": "Master Hand",
          "icon": "media/master-hand.svg"
        }
      ]
    },
    "views": {
      "masterHand": [
        {
          "id": "masterHandSidebar",
          "name": "Suggestions",
          "icon": "media/master-hand.svg"
        }
      ]
    },
    "commands": [
      { "command": "masterHand.suggest", "title": "Refresh Suggestions", "category": "Master Hand", "icon": "$(refresh)" },
      { "command": "masterHand.plan", "title": "Plan Suggestions", "category": "Master Hand" },
      { "command": "masterHand.ask", "title": "Ask About Repo (or Selection)", "category": "Master Hand" },
      { "command": "masterHand.explain", "title": "Explain Diagnostic or Selection", "category": "Master Hand" },
      { "command": "masterHand.review", "title": "Review Uncommitted Changes", "category": "Master Hand" },
      { "command": "masterHand.commitMessage", "title": "Draft Commit Message", "category": "Master Hand" },
      { "command": "masterHand.todo", "title": "List TODO / FIXME / HACK", "category": "Master Hand" },
      { "command": "masterHand.test", "title": "Infer Test Command (Queue for Approval)", "category": "Master Hand" },
      { "command": "masterHand.goal", "title": "Set Long-Term Goal", "category": "Master Hand" },
      { "command": "masterHand.next", "title": "Set / Clear Short-Term Next Step", "category": "Master Hand" },
      { "command": "masterHand.reset", "title": "Reset Goals / Suggestions / All", "category": "Master Hand" },
      { "command": "masterHand.model", "title": "Pick Model", "category": "Master Hand" },
      { "command": "masterHand.modelStatus", "title": "Test Model Connection", "category": "Master Hand" },
      { "command": "masterHand.auth", "title": "Provider Auth Status / Login", "category": "Master Hand" },
      { "command": "masterHand.showContext", "title": "Show Context Snapshot", "category": "Master Hand" },
      { "command": "masterHand.showIndex", "title": "Show Repo Index", "category": "Master Hand" },
      { "command": "masterHand.status", "title": "Show Status Summary", "category": "Master Hand" },
      { "command": "masterHand.send", "title": "Send Suggestion to External Agent", "category": "Master Hand" },
      { "command": "masterHand.proposeDiff", "title": "Propose Diff (Queue for Approval)", "category": "Master Hand" },
      { "command": "masterHand.run", "title": "Queue Command for Approval", "category": "Master Hand" },
      { "command": "masterHand.pending", "title": "Show Pending Actions", "category": "Master Hand" },
      { "command": "masterHand.search", "title": "Search Repo (ripgrep)", "category": "Master Hand" },
      { "command": "masterHand.acceptSuggestion", "title": "Accept (Send to Agent)", "category": "Master Hand", "icon": "$(check)" },
      { "command": "masterHand.dismissSuggestion", "title": "Dismiss", "category": "Master Hand", "icon": "$(close)" },
      { "command": "masterHand.postponeSuggestion", "title": "Postpone", "category": "Master Hand", "icon": "$(clock)" },
      { "command": "masterHand.viewSuggestion", "title": "View Details", "category": "Master Hand", "icon": "$(eye)" },
      { "command": "masterHand.copySuggestion", "title": "Copy Agent Prompt", "category": "Master Hand" },
      { "command": "masterHand.openSuggestionFile", "title": "Open First Referenced File", "category": "Master Hand" },
      { "command": "masterHand.undoDismiss", "title": "Undo Last Dismiss", "category": "Master Hand" },
      { "command": "masterHand.approveAction", "title": "Approve", "category": "Master Hand", "icon": "$(check)" },
      { "command": "masterHand.rejectAction", "title": "Reject", "category": "Master Hand", "icon": "$(close)" },
      { "command": "masterHand.openSettings", "title": "Open Settings", "category": "Master Hand", "icon": "$(gear)" }
    ],
    "viewsWelcome": [
      {
        "view": "masterHandSidebar",
        "contents": "Repo-aware suggestions with an explicit approval boundary. Nothing is edited or run without your OK.\n[$(refresh) Refresh Suggestions](command:masterHand.suggest)\n[$(target) Set Long-Term Goal](command:masterHand.goal)\n[$(gear) Open Settings](command:masterHand.openSettings)\nWorks with local heuristics only; add a model via masterHand.model.provider for richer suggestions."
      }
    ],
    "menus": {
      "view/title": [
        { "command": "masterHand.suggest", "when": "view == masterHandSidebar", "group": "navigation@1" },
        { "command": "masterHand.openSettings", "when": "view == masterHandSidebar", "group": "navigation@2" },
        { "command": "masterHand.goal", "when": "view == masterHandSidebar", "group": "1_steer@1" },
        { "command": "masterHand.next", "when": "view == masterHandSidebar", "group": "1_steer@2" },
        { "command": "masterHand.plan", "when": "view == masterHandSidebar", "group": "1_steer@3" },
        { "command": "masterHand.undoDismiss", "when": "view == masterHandSidebar", "group": "2_edit@1" },
        { "command": "masterHand.reset", "when": "view == masterHandSidebar", "group": "2_edit@2" }
      ],
      "editor/context": [
        { "command": "masterHand.ask", "when": "editorTextFocus", "group": "1_masterhand@1" },
        { "command": "masterHand.explain", "when": "editorTextFocus", "group": "1_masterhand@2" }
      ],
      "scm/title": [
        { "command": "masterHand.commitMessage", "when": "scmProvider == git", "group": "1_masterhand@1" }
      ],
      "view/item/context": [
        { "command": "masterHand.acceptSuggestion", "when": "view == masterHandSidebar && viewItem == suggestion", "group": "inline@1" },
        { "command": "masterHand.dismissSuggestion", "when": "view == masterHandSidebar && viewItem == suggestion", "group": "inline@2" },
        { "command": "masterHand.viewSuggestion", "when": "view == masterHandSidebar && viewItem == suggestion", "group": "inline@3" },
        { "command": "masterHand.postponeSuggestion", "when": "view == masterHandSidebar && viewItem == suggestion", "group": "1_actions@1" },
        { "command": "masterHand.copySuggestion", "when": "view == masterHandSidebar && viewItem == suggestion", "group": "1_actions@2" },
        { "command": "masterHand.openSuggestionFile", "when": "view == masterHandSidebar && viewItem == suggestion", "group": "1_actions@3" },
        { "command": "masterHand.approveAction", "when": "view == masterHandSidebar && viewItem == pendingAction", "group": "inline@1" },
        { "command": "masterHand.rejectAction", "when": "view == masterHandSidebar && viewItem == pendingAction", "group": "inline@2" }
      ]
    },
    "configuration": {
      "title": "Master Hand",
      "properties": {
        "masterHand.proactivity": {
          "type": "string",
          "enum": ["passive", "advisory"],
          "default": "passive",
          "description": "passive: suggestions only on explicit commands. advisory: debounce-refresh suggestions after edits/diagnostics (still never edits or runs anything)."
        },
        "masterHand.suggestionFrequencyMs": {
          "type": "number",
          "default": 5000,
          "description": "Debounce for advisory-mode suggestion refreshes."
        },
        "masterHand.ignore": {
          "type": "array",
          "items": { "type": "string" },
          "default": [".git/", "node_modules/", "dist/", "build/", "out/", ".env", ".env.*"],
          "description": "Paths excluded from context, diffs, search, and proposed patches. Replaces the default list."
        },
        "masterHand.observation.buffers": { "type": "boolean", "default": true, "description": "Include open editor list in context." },
        "masterHand.observation.edits": { "type": "boolean", "default": true, "description": "Include recent edit locations in context." },
        "masterHand.observation.diagnostics": { "type": "boolean", "default": true, "description": "Include diagnostic counts in context." },
        "masterHand.observation.git": { "type": "boolean", "default": true, "description": "Include git status/diff in context." },
        "masterHand.model.provider": {
          "type": "string",
          "enum": ["none", "auto", "openai", "openai_compatible", "openrouter", "ollama", "ollama-cloud", "anthropic", "pi", "codex", "claude", "gemini", "cli"],
          "default": "auto",
          "description": "Model provider. auto = local Ollama when available; heuristics always work without a model."
        },
        "masterHand.model.name": { "type": "string", "default": "", "description": "Model name/id for the provider." },
        "masterHand.model.endpoint": { "type": "string", "default": "", "description": "Override provider endpoint URL." },
        "masterHand.model.apiKeyEnv": { "type": "string", "default": "", "description": "Environment variable holding the provider API key." },
        "masterHand.model.executable": { "type": "string", "default": "", "description": "Override executable for CLI providers (pi/codex/claude/gemini/cli)." },
        "masterHand.model.command": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Custom CLI provider argv template. \"$\" or {prompt} expands to the prompt; without either, the prompt goes to stdin. Shell strings are rejected."
        },
        "masterHand.model.loginCommand": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Custom login argv for the cli provider."
        },
        "masterHand.model.timeoutMs": { "type": "number", "default": 60000 },
        "masterHand.model.temperature": { "type": "number", "default": 0.2 },
        "masterHand.model.maxTokens": { "type": "number", "default": 1200 },
        "masterHand.model.selection": {
          "type": "string",
          "enum": ["auto", "fixed"],
          "default": "auto",
          "description": "auto: cloud-ranked routing when ranked candidates exist. fixed: always use the configured model."
        },
        "masterHand.model.cloudPolicy": {
          "type": "string",
          "enum": ["fallback", "best"],
          "default": "fallback",
          "description": "fallback: local candidates listed before cloud for the router. best: sort all candidates by rank."
        },
        "masterHand.model.ranked": {
          "type": "array",
          "items": { "type": "object" },
          "default": [],
          "description": "Ranked model candidates ({provider, name, rank, isLocal, ...}). Replaces the default list."
        },
        "masterHand.model.rankingModel": {
          "type": ["object", "null"],
          "default": null,
          "description": "Cloud model used only to pick a ranked candidate; defaults to the highest-ranked cloud candidate."
        },
        "masterHand.model.rankingMaxTokens": { "type": "number", "default": 24 },
        "masterHand.context.maxFiles": { "type": "number", "default": 80 },
        "masterHand.context.maxDiffBytes": { "type": "number", "default": 24000 },
        "masterHand.context.maxFileBytes": { "type": "number", "default": 12000 },
        "masterHand.context.maxSearchResults": { "type": "number", "default": 40 },
        "masterHand.context.maxModelCodeFiles": { "type": "number", "default": 8 },
        "masterHand.context.maxModelFileBytes": { "type": "number", "default": 12000 },
        "masterHand.context.includeRelatedFiles": { "type": "boolean", "default": true },
        "masterHand.context.includeSymbols": { "type": "boolean", "default": true },
        "masterHand.context.includeIndex": { "type": "boolean", "default": true },
        "masterHand.context.indexMaxFiles": { "type": "number", "default": 500 },
        "masterHand.context.indexMaxFileBytes": { "type": "number", "default": 20000 },
        "masterHand.context.indexMaxTodos": { "type": "number", "default": 40 },
        "masterHand.context.indexMaxSymbols": { "type": "number", "default": 80 },
        "masterHand.commands.allowlist": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["git", "make", "npm", "pnpm", "yarn", "cargo", "go", "pytest", "python", "node", "npx"],
          "description": "Commands the approval runner may execute. Replaces the default list."
        },
        "masterHand.commands.blocklist": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["rm", "sudo", "git reset", "git clean"],
          "description": "Commands the approval runner always refuses. Replaces the default list."
        },
        "masterHand.commands.timeoutMs": { "type": "number", "default": 10000 },
        "masterHand.agent.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Accepting a suggestion hands it to an external coding agent. false = feedback-only."
        },
        "masterHand.agent.adapter": {
          "type": "string",
          "enum": ["auto", "terminal", "pi", "codex"],
          "default": "auto",
          "description": "auto/terminal: run the agent in a VS Code terminal. pi/codex: same, with that executable."
        },
        "masterHand.agent.executable": { "type": "string", "default": "", "description": "Agent binary; defaults to pi, or codex when the adapter says codex." },
        "masterHand.agent.command": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Custom agent argv template. \"$\" or {prompt} expands to the prompt; {root} to the repo root. Shell strings are rejected."
        },
        "masterHand.storage.enabled": { "type": "boolean", "default": true, "description": "Persist goals/feedback per workspace." }
      }
    }
  }
}
